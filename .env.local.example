# ─────────────────────────────────────────────
# Supabase — create your project at supabase.com
# then paste the values from Settings > API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# Resend — create account at resend.com (free)
# then create an API key under API Keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here

# ─────────────────────────────────────────────
# Email config
# ─────────────────────────────────────────────
EMAIL_FROM=bookings@ucalrentacar.com
EMAIL_REPLY_TO=info@ucalrentacar.com
ADMIN_EMAIL=admin@ucalrentacar.com

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# In production: NEXT_PUBLIC_SITE_URL=https://ucalrentacar.com

# ─────────────────────────────────────────────
# Admin access — simple password for /admin
# ─────────────────────────────────────────────
ADMIN_SECRET=change-this-to-a-strong-password
